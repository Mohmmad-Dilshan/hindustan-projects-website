# ── Vite Environment Variables ────────────────────────────────
# Copy this file to .env.local for local dev
# Set these in Vercel dashboard for production

# Backend API URL
# Local:      leave empty (Vite proxy handles /api → localhost:5000)
# Production: your Render backend URL
VITE_API_URL=https://hindustan-projects-api.onrender.com/api

# Google reCAPTCHA v3 Site Key (public — safe to expose)
# Get from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
